# claude-brainlab — environment template
# Copy this file to .env and fill in your values, then run: bash install/setup.sh
# .env is git-ignored.
#
# IMPORTANT: quote any value that contains spaces (paths!), e.g.
#   OBSIDIAN_VAULT="/Users/me/Library/Mobile Documents/.../my-vault"

# ─── Obsidian vault ───────────────────────────────────────────────
# Folder name of your vault inside the iCloud Obsidian directory.
VAULT_NAME="my-vault"

# Full absolute path to the vault root.
# macOS iCloud default:
#   "$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/$VAULT_NAME"
# Plain local default:
#   "$HOME/Obsidian/$VAULT_NAME"
OBSIDIAN_VAULT="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/my-vault"

# ─── Project roots (filesystem) ───────────────────────────────────
# Where your research projects live on disk. Edit obsidian-projects.json
# after install to map FS roots → vault subfolders.
PAPERS_ROOT="$HOME/Papers"
PROJECTS_ROOT="$HOME/Projects"
STAFF_ROOT="$HOME/Staff"

# ─── Python interpreter ───────────────────────────────────────────
# Used by hooks and helper scripts. Use absolute path if you have a
# specific Python (conda/uv/system).
PYTHON_BIN="python3"

# ─── Zotero (optional, only needed for paper-ingest / want-2-read) ─
# Get API key at: https://www.zotero.org/settings/keys
# Find LIBRARY_ID at: https://www.zotero.org/<username> (numeric ID in URL)
ZOTERO_API_KEY=""
ZOTERO_LIBRARY_ID=""
UNPAYWALL_EMAIL="you@example.com"

# ─── User identity (used in some hooks/skills) ────────────────────
USER_EMAIL="you@example.com"
